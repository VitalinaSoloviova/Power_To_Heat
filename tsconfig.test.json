{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "types": ["jest"],
    "module": "commonjs",
    "target": "es2023",
    "moduleResolution": "node",
    "allowJs": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "erasableSyntaxOnly": false
  },
  "include": ["src/**/__tests__/**/*", "src/**/*.test.ts", "src/**/*.test.tsx"],
  "exclude": ["node_modules"]
}